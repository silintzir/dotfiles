{
  "list.height": 25,
  "list.alignColumns": true,
  "list.source.files.args": ["--hidden"],
  "list.source.mru.maxLength": 20,
  "coc.preferences.colorSupport": true,
  "signature.enable": false,
  "coc.preferences.formatOnSaveFiletypes": [
    "jsonc",
    "javascript",
    "html",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "css",
    "json",
    "lua"
  ],
  "eslint.alwaysShowStatus": true,
  "eslint.autoFixOnSave": true,
  "html.filetypes": ["html", "ejs", "handlebars"],
  "html.format.indentInnerHtml": true,
  /** tsserver */
  "tsserver.enableJavascript": true,
  "tsserver.enable": true,
  "lua.enable": true,
  "Lua.diagnostics.globals": ["hs", "use", "vim"],
  "prettier.printWidth": 120,
  "languageserver": {
    "graphql": {
      "command": "graphql-lsp",
      "args": ["server", "-m", "stream"],
      "filetypes": ["typescript", "typescriptreact", "javascript", "javascriptreact", "graphql"]
    }
  },
  "markdownlint.config": {
    "line_length": false
  },
  "Lua.diagnostics.enable": false,
  /** explorer presets */
  "explorer.activeMode": false,
  "explorer.position": "floating",
  "explorer.quitOnOpen": true,
  "explorer.floating.width": 120,
  "explorer.floating.height": 50,
  "explorer.openAction.strategy": "sourceWindow",
  "explorer.presets": {
    ".vim": {
      "root-uri": "~/.config/nvim",
      "sources": [{ "name": "file", "expand": true }]
    },
    "sources": {
      "sources": [{ "name": "file", "expand": true }]
    },
    "buffers": {
      "sources": [{ "name": "buffer", "expand": true }]
    }
  },
  "explorer.floating.border.title": "Explore files",
  "explorer.icon.enableNerdfont": true,
  "explorer.file.showHiddenFiles": true,
  "explorer.floating.hideOnCocList": true,
  "explorer.file.autoReveal": true
}
